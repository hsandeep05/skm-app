# For Vercel Postgres (Neon) - set these in Vercel Dashboard → Settings → Environment Variables
# After creating a Vercel Postgres database, use:
# DATABASE_URL = the pooled connection URL (POSTGRES_PRISMA_URL)
# DIRECT_URL = the direct connection URL (POSTGRES_URL_NON_POOLING)

# Local development placeholder (replace with actual PostgreSQL URL)
DATABASE_URL=postgresql://placeholder:placeholder@localhost:5432/skm
DIRECT_URL=postgresql://placeholder:placeholder@localhost:5432/skm
